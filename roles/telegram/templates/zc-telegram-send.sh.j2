#!/bin/bash
# Robust Telegram sender — Managed by Ansible (telegram role). Do not edit.
#
# Used by both the Wi-Fi connection test and the playbook's failure-notification
# rescue, so alerts are delivered reliably from anywhere in the run.
#
# Resolution strategy: try the system resolver first (normal networks). Only if
# that fails do we fall back to DNS-over-HTTPS (443, to public resolvers by IP)
# and pin the result with curl --resolve — needed on networks like this one,
# whose resolver FILTERS api.telegram.org by name (returns no A record) while
# the IP route and HTTPS (443) to Telegram stay open. Delivery is confirmed by
# an "ok":true response and retried with an escalating backoff.
#
# Usage: zc-telegram-send.sh "<html message>"   (or pipe the message on stdin)
set -u

BOT_TOKEN="{{ telegram_bot_token }}"
CHAT_ID="{{ telegram_chat_id }}"
PING_TARGET="{{ telegram_ping_target }}"
LOG="{{ telegram_send_log }}"
BACKOFFS=({{ telegram_backoffs }})
TG_HOST="api.telegram.org"
TG_IP=""

ts() { date '+%Y-%m-%d %H:%M:%S'; }
log() { echo "$(ts) $*" >> "$LOG"; }

# Message from $1, or stdin if no argument given.
MSG="${1:-}"
[ -z "$MSG" ] && MSG="$(cat)"

# Cap at 3500 bytes; flag if we had to cut.
max=3500
if [ "$(printf '%s' "$MSG" | wc -c)" -gt "$max" ]; then
  MSG="$(printf '%s' "$MSG" | head -c $((max - 80)))"
  MSG="${MSG}"$'\n\n'"… ✂️ <i>truncated — 3500-byte limit exceeded</i>"
fi

# Resolve an A record over DoH (HTTPS/443) via public resolvers addressed by IP.
resolve_via_doh() {
  local host="$1" url ip
  for url in "https://8.8.8.8/resolve?name=${host}&type=A" \
             "https://1.1.1.1/dns-query?name=${host}&type=A"; do
    ip="$(curl -sS -m 8 "$url" -H 'accept: application/dns-json' 2>/dev/null \
          | grep -oE '"data":"[0-9.]+"' | head -1 | grep -oE '[0-9.]+')"
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  done
  return 1
}

# Wait briefly for basic internet (radio may still be settling after a switch).
net_ready() {
  local i
  for i in $(seq 1 "${1:-10}"); do
    ping -c 1 -W 2 "$PING_TARGET" >/dev/null 2>&1 && return 0
    sleep 1
  done
  return 1
}

attempt=0
for delay in "${BACKOFFS[@]}"; do
  attempt=$((attempt + 1))
  if [ "$delay" -gt 0 ]; then
    log "waiting ${delay}s before attempt ${attempt}"
    sleep "$delay"
  fi

  net_ready 10 || log "attempt ${attempt}: no internet yet, trying anyway"
  # Resolve once: system DNS first (normal networks), DoH only if that fails
  # (this network filters api.telegram.org on plain DNS). Pin the result so the
  # send uses it on whichever Wi-Fi we ended up on.
  if [ -z "$TG_IP" ]; then
    TG_IP="$(getent ahostsv4 "$TG_HOST" 2>/dev/null | awk '{print $1; exit}')"
    if [ -n "$TG_IP" ]; then
      log "resolved ${TG_HOST} -> ${TG_IP} (system DNS)"
    else
      TG_IP="$(resolve_via_doh "$TG_HOST" || true)"
      [ -n "$TG_IP" ] && log "resolved ${TG_HOST} -> ${TG_IP} (DoH fallback)"
    fi
  fi
  resolve_opt=()
  [ -n "$TG_IP" ] && resolve_opt=(--resolve "${TG_HOST}:443:${TG_IP}")

  # Confirm real delivery via "ok":true, not just a zero curl exit.
  resp="$(curl -sS -m 15 "${resolve_opt[@]}" -X POST \
    "https://${TG_HOST}/bot${BOT_TOKEN}/sendMessage" \
    -d chat_id="${CHAT_ID}" \
    -d parse_mode="HTML" \
    -d disable_web_page_preview="true" \
    --data-urlencode text="${MSG}" 2>>"$LOG")"
  echo "$resp" >> "$LOG"

  if printf '%s' "$resp" | grep -q '"ok":true'; then
    log "DELIVERED (attempt ${attempt}, ip=${TG_IP:-dns})"
    exit 0
  fi
  log "attempt ${attempt} not confirmed (no ok:true)"
done

log "FAILED after ${attempt} attempts"
exit 1
