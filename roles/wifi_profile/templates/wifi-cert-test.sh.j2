#!/bin/bash
# Detached Wi-Fi connection test with ping verification and fallback.
# Managed by Ansible (wifi_profile role) â€” do not edit by hand.
#
# Runs independently of the SSH/Ansible session because activating the cert
# Wi-Fi drops the fallback Wi-Fi on the same radio (and thus any SSH link).
#
# Flow:
#   1. Try to bring up the cert connection (waits up to TIMEOUT seconds).
#   2. If it does not activate -> fall back to the previous Wi-Fi.
#   3. If it activates -> ping test. Ping fails -> fall back. Ping OK -> STAY.
#   4. If fell back, wait for internet to be restored on the fallback link.
#   5. Send a Telegram summary of the whole attempt (always, even on error).
set -u

CERT_CON="{{ wifi_con_name }}"
MGMT_CON="{{ wifi_mgmt_con }}"
SSID="{{ wifi_ssid }}"
TIMEOUT={{ wifi_connect_timeout }}
PING_TARGET="{{ wifi_ping_target }}"
PING_COUNT={{ wifi_ping_count }}
RESTORE_WAIT={{ wifi_internet_restore_wait }}
LOG="{{ wifi_test_log }}"
STATUS="{{ wifi_test_status }}"
BOT_TOKEN="{{ telegram_bot_token }}"
CHAT_ID="{{ telegram_chat_id }}"
HOST="$(hostname)"

ts() { date '+%Y-%m-%d %H:%M:%S'; }
log() { echo "$(ts) $*" >> "$LOG"; }

# --- Telegram summary -----------------------------------------------------
# Lines accumulate in SUMMARY as the test progresses; one message is sent at
# the very end (or on early exit via the trap), HTML-formatted.
SUMMARY=""
add() { SUMMARY="${SUMMARY}${1}"$'\n'; }

# The network's DNS resolver (port 53) FILTERS api.telegram.org by name â€” it
# returns no A record on both the cert and management segments â€” while the IP
# route and HTTPS (443) to Telegram stay open. So we resolve the name over
# DNS-over-HTTPS (port 443, to public resolvers by IP), which bypasses the
# filter, then pin the IP with curl --resolve for the actual send.
TG_HOST="api.telegram.org"
TG_IP=""

# Resolve an A record over DoH (HTTPS/443) via public resolvers addressed by IP,
# so it works with no usable plain DNS. Echoes the first IPv4 found.
resolve_via_doh() {
  local host="$1" url ip
  for url in "https://8.8.8.8/resolve?name=${host}&type=A" \
             "https://1.1.1.1/dns-query?name=${host}&type=A"; do
    ip="$(curl -sS -m 8 "$url" -H 'accept: application/dns-json' 2>/dev/null \
          | grep -oE '"data":"[0-9.]+"' | head -1 | grep -oE '[0-9.]+')"
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  done
  return 1
}

send_telegram() {
  local text="$1"
  local max=3500
  # Telegram/our own cap: trim to max bytes and flag if we cut anything.
  if [ "$(printf '%s' "$text" | wc -c)" -gt "$max" ]; then
    text="$(printf '%s' "$text" | head -c $((max - 80)))"
    text="${text}"$'\n\n'"â€¦ âś‚ď¸Ź <i>truncated â€” 3500-byte limit exceeded</i>"
  fi
  # Pin the pre-resolved IP if we have one (DNS is blocked on the cert network).
  local resolve_opt=()
  if [ -n "$TG_IP" ]; then
    resolve_opt=(--resolve "${TG_HOST}:443:${TG_IP}")
  fi
  # Retry: even with the IP pinned, the radio may still be settling right after
  # a switch. Use -sS (not -s) so curl errors are logged for diagnosis.
  local attempt rc
  for attempt in 1 2 3 4 5; do
    rc=0
    curl -sS -m 15 "${resolve_opt[@]}" -X POST \
      "https://${TG_HOST}/bot${BOT_TOKEN}/sendMessage" \
      -d chat_id="${CHAT_ID}" \
      -d parse_mode="HTML" \
      -d disable_web_page_preview="true" \
      --data-urlencode text="${text}" >> "$LOG" 2>&1 || rc=$?
    if [ "$rc" -eq 0 ]; then
      log "telegram sent (attempt $attempt, ip=${TG_IP:-dns})"
      return 0
    fi
    log "telegram send failed (attempt $attempt, curl rc=$rc) â€” retrying in 3s"
    sleep 3
  done
  log "telegram send FAILED after 5 attempts"
  return 1
}

# Guarantee a summary is sent even if the script dies unexpectedly.
sent=0
finish() {
  if [ "$sent" -eq 0 ]; then
    sent=1
    send_telegram "$SUMMARY"
  fi
  log "=== wifi cert connection test END (status=$(cat "$STATUS" 2>/dev/null)) ==="
}
trap finish EXIT

ip4_of() {
  nmcli -t -f IP4.ADDRESS connection show "$1" 2>/dev/null | head -1 | cut -d: -f2
}

restore_mgmt() {
  log "falling back to: $MGMT_CON"
  nmcli connection down "$CERT_CON" >> "$LOG" 2>&1
  nmcli connection delete "$CERT_CON" >> "$LOG" 2>&1
  nmcli connection up "$MGMT_CON" >> "$LOG" 2>&1
}

wait_internet() {
  # Poll until the fallback link can reach the internet again.
  local i
  for i in $(seq 1 "$RESTORE_WAIT"); do
    if ping -c 1 -W 2 "$PING_TARGET" >> "$LOG" 2>&1; then
      return 0
    fi
    sleep 2
  done
  return 1
}

log "=== wifi cert connection test START ==="
log "cert=$CERT_CON fallback=$MGMT_CON timeout=${TIMEOUT}s ping=$PING_TARGET"

# Resolve Telegram via DoH up front (the network filters it on plain DNS); the
# pinned IP is used for the final notification regardless of which net we end on.
TG_IP="$(resolve_via_doh "$TG_HOST" || true)"
log "pre-resolved (DoH) $TG_HOST -> ${TG_IP:-FAILED (will fall back to plain DNS)}"

add "đź“¶ <b>Cert Wi-Fi enrolment</b>"
add "Host: <code>${HOST}</code>"
add "<code>$(ts)</code>"
add "SSID <code>${SSID}</code> Â· fallback <code>${MGMT_CON}</code>"
add ""

# Include cert details written by scep_enroll (CN, expiry, new vs existing).
if [ -f /var/log/zc-enroll.status ]; then
  _enrolled=$(grep '^ENROLLED=' /var/log/zc-enroll.status | cut -d= -f2-)
  _subject=$(grep '^SUBJECT='  /var/log/zc-enroll.status | cut -d= -f2-)
  add "Cert: <code>${_subject}</code>"
  if [ "$_enrolled" = "NEW" ]; then
    add "Enrolment: new certificate issued"
  else
    add "Enrolment: existing certificate reused"
  fi
  add ""
fi

# --- Step 1/2: try to activate the cert connection ------------------------
log "activating $CERT_CON ..."
nmcli connection up "$CERT_CON" >> "$LOG" 2>&1 &

ok=0
for i in $(seq 1 "$TIMEOUT"); do
  if nmcli -t -f NAME,STATE connection show --active 2>/dev/null \
       | grep -q "^${CERT_CON}:activated"; then
    ok=1
    break
  fi
  sleep 1
done

if [ "$ok" -ne 1 ]; then
  # --- Step 3a: never associated -> fall back ----------------------------
  log "FAIL: $CERT_CON did not activate within ${TIMEOUT}s"
  echo "FAIL" > "$STATUS"
  add "âťŚ Did not associate to <code>${SSID}</code> within ${TIMEOUT}s"
  restore_mgmt
  if wait_internet; then
    add "Fell back to <code>${MGMT_CON}</code> â€” internet OK"
  else
    add "Fell back to <code>${MGMT_CON}</code> â€” internet not confirmed"
  fi
  add ""
  add "âťŚ <b>Result: FAILED</b> (profile rolled back)"
  exit 0
fi

# --- Associated: report and run the ping test -----------------------------
ip4="$(ip4_of "$CERT_CON")"
log "associated to $SSID, IP ${ip4:-unknown} â€” running ping test"
add "âś… Associated to <code>${SSID}</code> (EAP-TLS OK)"
add "    IP <code>${ip4:-unknown}</code>"

if ping -c "$PING_COUNT" -W 2 "$PING_TARGET" >> "$LOG" 2>&1; then
  # --- Step 4 success: ping OK -> STAY on cert ---------------------------
  log "SUCCESS: ping $PING_TARGET OK â€” staying on $CERT_CON"
  echo "SUCCESS" > "$STATUS"
  add "Ping ${PING_TARGET}: OK"
  add ""
  add "âś… <b>Result: connected to <code>${SSID}</code> â€” staying.</b>"
  exit 0
fi

# --- Step 4 fallback: associated but no internet -> fall back -------------
log "ping $PING_TARGET FAILED â€” rolling back"
echo "FALLBACK" > "$STATUS"
add "Ping ${PING_TARGET}: failed"
restore_mgmt
if wait_internet; then
  add "Fell back to <code>${MGMT_CON}</code> â€” internet OK"
else
  add "Fell back to <code>${MGMT_CON}</code> â€” internet not confirmed"
fi
add ""
add "âťŚ <b>Result: FALLBACK</b> (cert had no internet, profile rolled back)"
exit 0
